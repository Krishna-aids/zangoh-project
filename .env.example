# Copy this file to .env and fill in your values.
#
# Implemented default path:
# - STT: Groq Whisper
# - LLM: Groq chat completions
# - TTS: Edge TTS

# ----------------------------
# Required for default setup
# ----------------------------
# Used by both STT and LLM when STT_API_KEY / LLM_API_KEY are not set.
GROQ_API_KEY=your_groq_api_key_here

# ----------------------------
# Provider selection (optional)
# ----------------------------
STT_PROVIDER=groq
LLM_PROVIDER=groq
TTS_PROVIDER=edge

# ----------------------------
# API key mapping (optional overrides)
# ----------------------------
# Preferred generic keys (provider-agnostic):
STT_API_KEY=
LLM_API_KEY=
TTS_API_KEY=

# ----------------------------
# STT settings (optional)
# ----------------------------
# Generic first, provider-specific fallback second:
STT_MODEL=whisper-large-v3-turbo
GROQ_STT_MODEL=whisper-large-v3-turbo
STT_LANGUAGE=
STT_TIMEOUT_SECONDS=20
STT_MAX_CHUNK_BYTES=5242880

# ----------------------------
# LLM settings (optional)
# ----------------------------
LLM_MODEL=llama-3.1-8b-instant
GROQ_LLM_MODEL=llama-3.1-8b-instant
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=30

# ----------------------------
# TTS settings (optional)
# ----------------------------
TTS_VOICE=en-US-AriaNeural
EDGE_TTS_VOICE=en-US-AriaNeural
TTS_RATE=+0%
EDGE_TTS_RATE=+0%
TTS_VOLUME=+0%
EDGE_TTS_VOLUME=+0%
TTS_TIMEOUT_SECONDS=20

# ----------------------------
# Streaming endpoint tuning (optional)
# ----------------------------
WS_STREAM_QUEUE_MAXSIZE=32
WS_STREAM_MAX_FRAME_BYTES=524288
WS_STREAM_QUEUE_PUT_TIMEOUT_SECONDS=0.5
